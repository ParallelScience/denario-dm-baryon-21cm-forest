            if m_record is None:
                kl_divs[m].append(np.nan)
            else:
                q = np.array(m_record['dN_dtau'])
                kl = compute_kl_divergence(p, q)
                kl_divs[m].append(kl)
    fig2, ax2 = plt.subplots(figsize=(8, 6))
